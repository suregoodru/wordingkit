{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "wordingkit",
  "version": "1.0.0",
  "title": "WordingKit",
  "description": "Improve selected writing in any macOS app with local or cloud models.",
  "icon": "icon.png",
  "author": "suregoodru",
  "homepage": "https://github.com/suregoodru/wordingkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suregoodru/wordingkit.git"
  },
  "bugs": {
    "url": "https://github.com/suregoodru/wordingkit/issues"
  },
  "categories": [
    "Productivity"
  ],
  "keywords": [
    "writing",
    "wording",
    "tone",
    "grammar",
    "style",
    "raycast",
    "ollama",
    "openai",
    "anthropic",
    "groq"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Rewrite This",
      "subtitle": "WordingKit",
      "description": "Rewrite selected text using AI",
      "mode": "view"
    },
    {
      "name": "settings",
      "title": "WordingKit Settings",
      "subtitle": "WordingKit",
      "description": "Open all WordingKit settings",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "openaiApiKey",
      "title": "OpenAI API Key",
      "description": "API key for OpenAI models",
      "type": "password",
      "required": false
    },
    {
      "name": "anthropicApiKey",
      "title": "Anthropic API Key",
      "description": "API key for Anthropic models",
      "type": "password",
      "required": false
    },
    {
      "name": "groqApiKey",
      "title": "Groq API Key",
      "description": "API key for Groq models",
      "type": "password",
      "required": false
    },
    {
      "name": "ollamaUrl",
      "title": "Ollama URL",
      "description": "Local Ollama API address",
      "type": "textfield",
      "required": false,
      "default": "http://127.0.0.1:11434"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.21"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "~26.1.0",
    "@types/react": "^19.0.8",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    }
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --test test/*.test.ts",
    "eval:generate-modes": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/generate-manual-eval-modes.ts",
    "eval:rewrites": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/evaluate-rewrites.ts",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
